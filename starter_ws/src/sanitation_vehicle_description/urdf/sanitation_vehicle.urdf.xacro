<?xml version="1.0"?>
<robot name="sanitation_vehicle" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Reuse maintained Linorobot2 macros without modifying upstream source. -->
  <xacro:include filename="$(find linorobot2_description)/urdf/sensors/imu.urdf.xacro"/>
  <xacro:include filename="$(find linorobot2_description)/urdf/controllers/skid_steer.urdf.xacro"/>

  <!-- Stage4S separates physical geometry from the DiffDrive estimator / command
       model. Defaults reproduce the Stage4R vehicle exactly. -->
  <xacro:arg name="physical_wheel_radius" default="0.14"/>
  <xacro:arg name="physical_track_width" default="0.80"/>
  <xacro:arg name="drive_wheel_radius" default="0.14"/>
  <xacro:arg name="drive_wheel_separation" default="0.80"/>
  <xacro:arg name="wheel_mu_longitudinal" default="1.0"/>
  <xacro:arg name="wheel_mu_lateral" default="1.0"/>
  <xacro:arg name="slip_compliance_longitudinal" default="0.0"/>
  <xacro:arg name="slip_compliance_lateral" default="0.0"/>
  <xacro:arg name="enable_wheel_slip" default="false"/>

  <!-- Baseline geometry; replace with measured real vehicle values later. -->
  <xacro:property name="base_length" value="1.15"/>
  <xacro:property name="base_width" value="0.72"/>
  <xacro:property name="base_height" value="0.28"/>
  <xacro:property name="base_mass" value="80.0"/>
  <xacro:property name="physical_wheel_radius" value="$(arg physical_wheel_radius)"/>
  <xacro:property name="physical_track_width" value="$(arg physical_track_width)"/>
  <xacro:property name="drive_wheel_radius" value="$(arg drive_wheel_radius)"/>
  <xacro:property name="drive_wheel_separation" value="$(arg drive_wheel_separation)"/>
  <xacro:property name="wheel_mu_longitudinal" value="$(arg wheel_mu_longitudinal)"/>
  <xacro:property name="wheel_mu_lateral" value="$(arg wheel_mu_lateral)"/>
  <xacro:property name="slip_compliance_longitudinal" value="$(arg slip_compliance_longitudinal)"/>
  <xacro:property name="slip_compliance_lateral" value="$(arg slip_compliance_lateral)"/>
  <xacro:property name="wheel_width" value="0.08"/>
  <xacro:property name="wheel_pos_x" value="0.38"/>
  <xacro:property name="wheel_pos_y" value="${physical_track_width / 2.0}"/>
  <xacro:property name="wheel_pos_z" value="-0.02"/>
  <xacro:property name="wheel_mass" value="3.0"/>
  <xacro:property name="cleaning_width" value="0.65"/>

  <!-- Local primitive chassis avoids the upstream Gazebo-classic visual
       override colliding with URDF materials in Ogre2 / Gazebo Harmonic. -->
  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="sanitation_chassis_yellow">
        <color rgba="0.84 0.63 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <inertia
        ixx="${(base_mass / 12.0) * (base_width**2 + base_height**2)}"
        ixy="0" ixz="0"
        iyy="${(base_mass / 12.0) * (base_length**2 + base_height**2)}"
        iyz="0"
        izz="${(base_mass / 12.0) * (base_length**2 + base_width**2)}"/>
    </inertial>
  </link>
  <joint name="base_to_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${physical_wheel_radius - wheel_pos_z}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="sanitation_wheel" params="side pos_x pos_y red green blue">
    <link name="${side}_wheel_link">
      <visual>
        <origin rpy="${pi / 2.0} 0 0"/>
        <geometry><cylinder radius="${physical_wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="${side}_wheel_material">
          <color rgba="${red} ${green} ${blue} 1.0"/>
        </material>
      </visual>
      <collision>
        <origin rpy="${pi / 2.0} 0 0"/>
        <geometry><cylinder radius="${physical_wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${(wheel_mass / 12.0) * (3.0 * physical_wheel_radius**2 + wheel_width**2)}"
          ixy="0" ixz="0"
          iyy="${0.5 * wheel_mass * physical_wheel_radius**2}"
          iyz="0"
          izz="${(wheel_mass / 12.0) * (3.0 * physical_wheel_radius**2 + wheel_width**2)}"/>
      </inertial>
    </link>
    <joint name="${side}_wheel_joint" type="continuous">
      <axis xyz="0 1 0"/>
      <parent link="base_link"/>
      <child link="${side}_wheel_link"/>
      <origin xyz="${pos_x} ${pos_y} ${wheel_pos_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${side}_wheel_link">
      <mu1>${wheel_mu_longitudinal}</mu1>
      <mu2>${wheel_mu_lateral}</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:sanitation_wheel side="front_left" pos_x="${wheel_pos_x}" pos_y="${wheel_pos_y}"
    red="0.12" green="0.32" blue="0.62"/>
  <xacro:sanitation_wheel side="front_right" pos_x="${wheel_pos_x}" pos_y="${-wheel_pos_y}"
    red="0.13" green="0.33" blue="0.63"/>
  <xacro:sanitation_wheel side="rear_left" pos_x="${-wheel_pos_x}" pos_y="${wheel_pos_y}"
    red="0.14" green="0.34" blue="0.64"/>
  <xacro:sanitation_wheel side="rear_right" pos_x="${-wheel_pos_x}" pos_y="${-wheel_pos_y}"
    red="0.15" green="0.35" blue="0.65"/>

  <xacro:imu/>

  <link name="laser">
    <visual>
      <geometry><cylinder radius="0.045" length="0.06"/></geometry>
      <material name="sanitation_lidar_green"><color rgba="0.02 0.55 0.20 1.0"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.045" length="0.06"/></geometry></collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00006" ixy="0" ixz="0" iyy="0.00006" iyz="0" izz="0.00010"/>
    </inertial>
  </link>
  <joint name="laser_to_base_link" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.12 0 0.48" rpy="0 0 0"/>
  </joint>
  <gazebo reference="laser">
    <sensor name="sanitation_gpu_lidar" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.1416</min_angle>
            <max_angle>3.1416</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range><min>0.08</min><max>12.0</max><resolution>0.01</resolution></range>
      </lidar>
    </sensor>
  </gazebo>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.14 0.05"/></geometry>
      <material name="sanitation_camera_red"><color rgba="0.45 0.05 0.05 1.0"/></material>
    </visual>
    <collision><geometry><box size="0.05 0.14 0.05"/></geometry></collision>
    <inertial>
      <mass value="0.135"/>
      <inertia ixx="0.00025" ixy="0" ixz="0" iyy="0.00006" iyz="0" izz="0.00025"/>
    </inertial>
  </link>
  <joint name="camera_to_base_link" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.53 0 0.22" rpy="0 0 0"/>
  </joint>
  <link name="camera_depth_link"/>
  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <gazebo reference="camera_link">
    <sensor name="sanitation_rgbd_camera" type="rgbd_camera">
      <topic>camera</topic>
      <update_rate>15</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <camera>
        <optical_frame_id>camera_depth_link</optical_frame_id>
        <horizontal_fov>1.50098</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.3</near><far>100</far></clip>
      </camera>
    </sensor>
  </gazebo>

  <xacro:diff_drive_controller
    wheel_separation="${drive_wheel_separation}"
    wheel_radius="${drive_wheel_radius}"
  />

  <!-- Disabled by default so the split-parameter baseline exactly preserves
       Stage4R contact behavior. It is enabled only for an explicit slip scan. -->
  <xacro:if value="$(arg enable_wheel_slip)">
    <gazebo>
      <plugin filename="gz-sim-wheel-slip-system" name="gz::sim::systems::WheelSlip">
        <xacro:macro name="slip_wheel" params="link_name">
          <wheel link_name="${link_name}">
            <wheel_radius>${physical_wheel_radius}</wheel_radius>
            <slip_compliance_lateral>${slip_compliance_lateral}</slip_compliance_lateral>
            <slip_compliance_longitudinal>${slip_compliance_longitudinal}</slip_compliance_longitudinal>
            <wheel_normal_force>250.0</wheel_normal_force>
          </wheel>
        </xacro:macro>
        <xacro:slip_wheel link_name="front_left_wheel_link"/>
        <xacro:slip_wheel link_name="front_right_wheel_link"/>
        <xacro:slip_wheel link_name="rear_left_wheel_link"/>
        <xacro:slip_wheel link_name="rear_right_wheel_link"/>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- Model-scoped Gazebo truth. Unlike the world Pose_V bridge, this topic
       has one producer bound to this model and preserves an explicit frame
       identity all the way into ROS. It is evaluation-only and must never be
       fused into the realistic odometry / localization lane. -->
  <gazebo>
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/ground_truth/model_odom_raw</odom_topic>
      <odom_frame>world</odom_frame>
      <robot_base_frame>sanitation_vehicle/base_footprint</robot_base_frame>
      <dimensions>2</dimensions>
    </plugin>
  </gazebo>

  <!-- 40 L bin: 0.50 * 0.40 * 0.20 = 0.040 m^3. -->
  <link name="dust_bin_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.50 0.40 0.20"/></geometry>
      <material name="bin_green"><color rgba="0.12 0.42 0.22 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.50 0.40 0.20"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.133" ixy="0" ixz="0" iyy="0.193" iyz="0" izz="0.273"/>
    </inertial>
  </link>
  <joint name="dust_bin_joint" type="fixed">
    <parent link="base_link"/>
    <child link="dust_bin_link"/>
    <origin xyz="-0.18 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- Side brushes are fixed visual/collision placeholders in Stage 2.
       Codex should add controllable joints/cleaning semantics later. -->
  <link name="left_brush_link">
    <visual>
      <geometry><cylinder radius="0.14" length="0.03"/></geometry>
      <material name="left_brush_dark"><color rgba="0.08 0.08 0.08 1.0"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.14" length="0.03"/></geometry></collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.00495" ixy="0" ixz="0" iyy="0.00495" iyz="0" izz="0.0098"/>
    </inertial>
  </link>
  <joint name="left_brush_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_brush_link"/>
    <origin xyz="0.58 0.23 -0.14" rpy="0 0 0"/>
  </joint>

  <link name="right_brush_link">
    <visual>
      <geometry><cylinder radius="0.14" length="0.03"/></geometry>
      <material name="right_brush_dark"><color rgba="0.09 0.09 0.09 1.0"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.14" length="0.03"/></geometry></collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.00495" ixy="0" ixz="0" iyy="0.00495" iyz="0" izz="0.0098"/>
    </inertial>
  </link>
  <joint name="right_brush_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_brush_link"/>
    <origin xyz="0.58 -0.23 -0.14" rpy="0 0 0"/>
  </joint>

  <!-- Non-colliding visualization of the nominal cleaning footprint. -->
  <link name="cleaning_footprint_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.32 ${cleaning_width} 0.005"/></geometry>
      <material name="cleaning_zone"><color rgba="0.1 0.8 0.3 0.18"/></material>
    </visual>
  </link>
  <joint name="cleaning_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="cleaning_footprint_link"/>
    <origin xyz="0.55 0 -0.155" rpy="0 0 0"/>
  </joint>

  <!-- Mounting point reserved for a future manipulator. -->
  <link name="arm_mount_link"/>
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_mount_link"/>
    <origin xyz="0.10 0 0.32" rpy="0 0 0"/>
  </joint>

</robot>
