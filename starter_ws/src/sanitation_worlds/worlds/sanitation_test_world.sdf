<?xml version="1.0"?>
<sdf version="1.9">
  <world name="sanitation_test_world">

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.81</gravity>
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.65 0.65 0.65 1</ambient>
      <background>0.85 0.92 1.0 1</background>
      <shadows>true</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -1.0</direction>
    </light>

    <!-- Asphalt ground -->
    <model name="asphalt_ground">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>60 40 0.10</size></box></geometry>
          <surface>
            <friction><ode><mu>0.85</mu><mu2>0.85</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>60 40 0.10</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.18 1</ambient>
            <diffuse>0.22 0.22 0.22 1</diffuse>
          </material>
        </visual>
      </link>
      <pose>0 0 -0.05 0 0 0</pose>
    </model>

    <!-- Sidewalk strips and curbs -->
    <model name="north_sidewalk">
      <static>true</static>
      <pose>0 12 0.08 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>50 4 0.16</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>50 4 0.16</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.65 0.65 0.65 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="south_sidewalk">
      <static>true</static>
      <pose>0 -12 0.08 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>50 4 0.16</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>50 4 0.16</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.65 0.65 0.65 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Narrow corridor walls -->
    <model name="corridor_wall_left">
      <static>true</static>
      <pose>15 3.2 0.45 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>10 0.25 0.9</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>10 0.25 0.9</size></box></geometry></visual>
      </link>
    </model>
    <model name="corridor_wall_right">
      <static>true</static>
      <pose>15 1.6 0.45 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>10 0.25 0.9</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>10 0.25 0.9</size></box></geometry></visual>
      </link>
    </model>

    <!-- Low-friction 1 cm puddle region -->
    <model name="puddle_zone">
      <static>true</static>
      <pose>3 -5 0.005 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5 3 0.01</size></box></geometry>
          <surface>
            <friction><ode><mu>0.25</mu><mu2>0.25</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>5 3 0.01</size></box></geometry>
          <material>
            <ambient>0.05 0.25 0.55 0.45</ambient>
            <diffuse>0.05 0.35 0.75 0.45</diffuse>
          </material>
          <transparency>0.55</transparency>
        </visual>
      </link>
    </model>

    <!-- Static obstacles -->
    <model name="trash_bin_obstacle">
      <static>true</static>
      <pose>2 3 0.45 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.7 0.7 0.9</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.7 0.7 0.9</size></box></geometry>
          <material><ambient>0.1 0.35 0.15 1</ambient><diffuse>0.1 0.45 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="cardboard_box_obstacle">
      <static>true</static>
      <pose>8 -1 0.35 0 0 0.25</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.9 0.7 0.7</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.9 0.7 0.7</size></box></geometry>
          <material><ambient>0.55 0.32 0.12 1</ambient><diffuse>0.65 0.42 0.18 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Discrete garbage objects with semantic model names -->
    <model name="trash_bottle_01">
      <static>true</static>
      <pose>-1 1 0.12 1.57 0 0.4</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.045</radius><length>0.24</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.045</radius><length>0.24</length></cylinder></geometry>
          <material><ambient>0.1 0.35 0.8 1</ambient><diffuse>0.15 0.45 0.9 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="trash_can_01">
      <static>true</static>
      <pose>5 5 0.055 1.57 0 0.2</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.035</radius><length>0.11</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.035</radius><length>0.11</length></cylinder></geometry>
          <material><ambient>0.75 0.1 0.1 1</ambient><diffuse>0.9 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="trash_paper_01">
      <static>true</static>
      <pose>10 -5 0.012 0 0 0.5</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.24 0.18 0.02</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.24 0.18 0.02</size></box></geometry>
          <material><ambient>0.9 0.9 0.8 1</ambient><diffuse>1 1 0.9 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Simplified leaf pile, under 3 cm high -->
    <model name="leaf_pile_01">
      <static>true</static>
      <pose>-4 -4 0.015 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.8 1.2 0.03</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.8 1.2 0.03</size></box></geometry>
          <material><ambient>0.45 0.18 0.03 1</ambient><diffuse>0.65 0.28 0.05 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
