{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SanitationMission",
  "type": "object",
  "required": [
    "mission_id",
    "mode"
  ],
  "properties": {
    "mission_id": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "coverage",
        "waypoint",
        "spot_clean",
        "inspect",
        "return_home"
      ]
    },
    "schedule": {
      "type": [
        "string",
        "null"
      ]
    },
    "frame_id": {
      "type": "string",
      "default": "map"
    },
    "outer_polygon": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          {
            "type": "number"
          },
          {
            "type": "number"
          }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "exclusion_polygons": {"type": "array"},
    "keepout_polygons": {"type": "array"},
    "static_obstacles": {"type": "array"},
    "world_to_map_translation": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "number"}
    },
    "headland": {"type": "object"},
    "safety_margin_m": {"type": "number"},
    "operation_width_m": {"type": "number"},
    "robot_footprint": {"type": "array"},
    "targets": {
      "type": "array"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_speed_mps": {
          "type": "number"
        },
        "avoid_puddles": {
          "type": "boolean"
        },
        "brush_enabled": {
          "type": "boolean"
        },
        "return_when_bin_full": {
          "type": "boolean"
        }
      }
    }
  }
}
